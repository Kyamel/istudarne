# Local development secrets. Copy to .dev.vars (gitignored) and fill in.
# In production, set each one with: wrangler secret put <NAME>

# Required: signs the JWT access tokens. Generate with: openssl rand -base64 32
JWT_SECRET="dev-only-secret-change-me"

# Optional: Resend API key (https://resend.com). When empty, verification
# emails are not sent — the verification link is logged to the console instead.
RESEND_API_KEY=""

# Optional: OpenAI API key for the async AI jobs (queue consumer).
OPENAI_API_KEY=""
