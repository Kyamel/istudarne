{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"lib": ["ES2022"],
		"types": ["node"],
		"paths": {
			"@api/*": ["./worker/*"]
		},
		"esModuleInterop": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"checkJs": false,
		"strict": true,
		"noEmit": true
	},
	"include": ["worker/**/*", "worker-configuration.d.ts"]
}
